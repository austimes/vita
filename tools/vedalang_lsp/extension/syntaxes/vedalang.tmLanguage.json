{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VedaLang",
  "scopeName": "source.vedalang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.vedalang",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vedalang",
          "match": "\\b(dsl_version|imports|commodities|technologies|technology_roles|stock_characterizations|spatial_layers|spatial_measure_sets|temporal_index_series|region_partitions|zone_overlays|sites|facilities|fleets|opportunities|networks|runs)\\b"
        },
        {
          "name": "keyword.other.vedalang",
          "match": "\\b(id|description|kind|provides|primary_service|technologies|inputs|outputs|emissions|commodity|factor|site|technology_role|stock|metric|observed|year|location|point|lat|lon|layer|members|mapping|value|base_year|currency_year|region_partition)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "variable.parameter.vedalang",
          "match": "\\b(efficiency|investment_cost|fixed_om_cost|variable_om_cost|import_price|lifetime|availability_factor|stock|existing_capacity|emission_factor|cap2act|activity_unit|capacity_unit)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.vedalang",
          "match": "\\b(primary|secondary|service|emission|material|certificate|polygon|point|constant|cop|efficiency|custom|installed_capacity|annual_activity)\\b"
        },
        {
          "name": "constant.language.vedalang",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vedalang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vedalang",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.vedalang",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.vedalang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.vedalang",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    }
  }
}
