{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://veda-devtools/explain.schema.json",
  "title": "VedaLang Explain Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "artifact_version",
    "dsl_version",
    "run_id",
    "objects",
    "traces"
  ],
  "properties": {
    "artifact_kind": {"const": "explain"},
    "artifact_version": {"type": "string"},
    "dsl_version": {"const": "0.3"},
    "run_id": {"type": "string"},
    "objects": {
      "type": "object",
      "additionalProperties": {"type": "object"}
    },
    "traces": {
      "type": "object",
      "additionalProperties": {"type": "object"}
    }
  }
}
