{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://veda-devtools/cpir.schema.json",
  "title": "VedaLang CPIR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "artifact_version",
    "dsl_version",
    "run_id",
    "model_regions",
    "processes",
    "transitions",
    "network_arcs"
  ],
  "properties": {
    "artifact_kind": {"const": "cpir"},
    "artifact_version": {"type": "string"},
    "dsl_version": {"const": "0.2"},
    "run_id": {"type": "string"},
    "model_regions": {"type": "array", "items": {"type": "string"}},
    "processes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "technology",
          "model_region",
          "model_stock_metric",
          "initial_stock",
          "flows"
        ],
        "properties": {
          "id": {"type": "string"},
          "source_role_instance": {"type": "string"},
          "source_opportunity": {"type": "string"},
          "technology": {"type": "string"},
          "model_region": {"type": "string"},
          "model_stock_metric": {"type": "string"},
          "initial_stock": {"type": "object"},
          "max_new_capacity": {"type": "object"},
          "flows": {"type": "array", "items": {"type": "object"}}
        },
        "anyOf": [
          {"required": ["source_role_instance"]},
          {"required": ["source_opportunity"]}
        ]
      }
    },
    "transitions": {"type": "array", "items": {"type": "object"}},
    "network_arcs": {"type": "array", "items": {"type": "object"}}
  }
}
