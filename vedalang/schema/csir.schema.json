{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://veda-devtools/csir.schema.json",
  "title": "VedaLang CSIR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "artifact_version",
    "dsl_version",
    "run_id",
    "base_year",
    "currency_year",
    "region_partition",
    "model_regions",
    "technology_roles",
    "sites",
    "technology_role_instances",
    "opportunities",
    "networks"
  ],
  "properties": {
    "artifact_kind": {"const": "csir"},
    "artifact_version": {"type": "string"},
    "dsl_version": {"const": "0.2"},
    "run_id": {"type": "string"},
    "base_year": {"type": "integer"},
    "currency_year": {"type": "integer"},
    "region_partition": {"type": "string"},
    "model_regions": {"type": "array", "items": {"type": "string"}},
    "technology_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "primary_service", "technologies"],
        "properties": {
          "id": {"type": "string"},
          "primary_service": {"type": "string"},
          "technologies": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "sites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "resolved_model_region", "trace_ids"],
        "properties": {
          "id": {"type": "string"},
          "resolved_model_region": {"type": "string"},
          "trace_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "technology_role_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source_asset",
          "technology_role",
          "model_region",
          "available_technologies",
          "initial_stock",
          "trace_ids"
        ],
        "properties": {
          "id": {"type": "string"},
          "source_asset": {"type": "string"},
          "technology_role": {"type": "string"},
          "model_region": {"type": "string"},
          "available_technologies": {"type": "array", "items": {"type": "string"}},
          "trace_ids": {"type": "array", "items": {"type": "string"}},
          "initial_stock": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["technology", "declared_metric", "stock_views", "trace_ids"],
              "properties": {
                "technology": {"type": "string"},
                "declared_metric": {"type": "string"},
                "stock_views": {"type": "object"},
                "trace_ids": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      }
    },
    "opportunities": {"type": "array", "items": {"type": "object"}},
    "networks": {"type": "array", "items": {"type": "object"}}
  }
}
