{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://veda-devtools/vedalang.schema.json",
  "title": "VedaLang Model",
  "description": "Schema for VedaLang source files - a typed DSL for VEDA models",
  "type": "object",
  "required": ["model"],
  "properties": {
    "model": {
      "type": "object",
      "required": ["name", "regions", "commodities"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Model name identifier"
        },
        "description": {
          "type": "string",
          "description": "Model description"
        },
        "regions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "List of region codes"
        },
        "milestone_years": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1900 },
          "minItems": 1,
          "description": "List of model milestone years (e.g., [2020, 2030, 2040, 2050]). First year is the model start year."
        },
        "unit_policy": {
          "$ref": "#/$defs/unit_policy",
          "description": "Unit validation policy (strict/permissive, basis, and allowed unit sets)"
        },
        "monetary": {
          "$ref": "#/$defs/monetary_policy",
          "description": "Canonical monetary unit + conversion tables for explicit cost normalization"
        },
        "timeslices": {
          "$ref": "#/$defs/timeslices",
          "description": "Timeslice structure for intra-annual temporal resolution"
        },
        "commodities": {
          "type": "array",
          "items": { "$ref": "#/$defs/commodity" },
          "description": "Commodity definitions"
        },
        "scenario_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario_parameter" },
          "description": "Scenario parameters (demand projections, prices, etc.)"
        },
        "trade_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/trade_link" },
          "description": "Inter-regional trade links"
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" },
          "description": "User constraints (emission caps, activity shares, etc.)"
        },
        "cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/case" },
          "description": "Model cases - named combinations of scenario parameters for different model runs"
        },
        "studies": {
          "type": "array",
          "items": { "$ref": "#/$defs/study" },
          "description": "Studies - collections of cases for comparison"
        }
      }
    },
    "segments": {
      "$ref": "#/$defs/segments",
      "description": "Sector/end_use segmentation for demand-side modeling"
    },
    "process_roles": {
      "type": "array",
      "items": { "$ref": "#/$defs/process_role" },
      "description": "Abstract process transformations (topology definitions)"
    },
    "process_variants": {
      "type": "array",
      "items": { "$ref": "#/$defs/process_variant" },
      "description": "Concrete technology implementations of process roles"
    },
    "availability": {
      "type": "array",
      "items": { "$ref": "#/$defs/availability_entry" },
      "description": "Where variants are available (regions/sectors/segments)"
    },
    "process_parameters": {
      "type": "array",
      "items": { "$ref": "#/$defs/process_parameter" },
      "description": "Selector-based parameter blocks for variants"
    },
    "demands": {
      "type": "array",
      "items": { "$ref": "#/$defs/demand" },
      "description": "Service commodity demands by region/sector/segment"
    },
    "diagnostics": {
      "$ref": "#/$defs/diagnostics_spec",
      "description": "Solve-independent diagnostics boundaries and metric definitions"
    }
  },
  "$defs": {
    "segments": {
      "type": "object",
      "description": "Sector/end_use segmentation configuration",
      "required": ["sectors"],
      "properties": {
        "sectors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["RES", "COM", "IND", "TRN", "AGR", "NE", "OTH"]
          },
          "minItems": 1,
          "description": "Demand sectors from TIMES DEM_SECT"
        },
        "end_uses": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "description": "Optional end-use types for finer granularity (e.g., lighting, heating)"
        }
      },
      "additionalProperties": false
    },
    "energy_unit": {
      "type": "string",
      "enum": ["PJ", "TJ", "GJ", "MWh", "GWh", "TWh", "MTOE", "KTOE"],
      "description": "Supported energy units"
    },
    "power_unit": {
      "type": "string",
      "enum": ["GW", "MW", "kW", "TW"],
      "description": "Supported power/capacity units"
    },
    "mass_unit": {
      "type": "string",
      "enum": ["Mt", "kt", "t", "Gt"],
      "description": "Supported mass units"
    },
    "currency_unit": {
      "type": "string",
      "enum": ["USD", "kUSD", "MUSD", "BUSD"],
      "description": "Supported currency units"
    },
    "service_unit": {
      "type": "string",
      "enum": ["Bvkm"],
      "description": "Supported service units"
    },
    "unit_symbol": {
      "type": "string",
      "enum": [
        "PJ", "TJ", "GJ", "MWh", "GWh", "TWh", "MTOE", "KTOE",
        "GW", "MW", "kW", "TW",
        "Mt", "kt", "t", "Gt",
        "USD", "kUSD", "MUSD", "BUSD",
        "Bvkm"
      ],
      "description": "Supported unit symbols"
    },
    "energy_basis": {
      "type": "string",
      "enum": ["HHV", "LHV"],
      "description": "Energy basis for fuel/energy-mass consistency"
    },
    "unit_policy": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["permissive", "strict"],
          "default": "permissive",
          "description": "Strict mode turns unit warnings into hard errors"
        },
        "energy_basis": {
          "$ref": "#/$defs/energy_basis",
          "description": "Default model-wide energy basis"
        },
        "forbid_unit_transform_processes": {
          "type": "boolean",
          "default": false,
          "description": "Reject pass-through processes that only transform units without physical conversion intent"
        },
        "allowed_units": {
          "type": "object",
          "properties": {
            "energy": {
              "type": "array",
              "items": { "$ref": "#/$defs/energy_unit" },
              "minItems": 1,
              "uniqueItems": true
            },
            "power": {
              "type": "array",
              "items": { "$ref": "#/$defs/power_unit" },
              "minItems": 1,
              "uniqueItems": true
            },
            "mass": {
              "type": "array",
              "items": { "$ref": "#/$defs/mass_unit" },
              "minItems": 1,
              "uniqueItems": true
            },
            "currency": {
              "type": "array",
              "items": { "$ref": "#/$defs/currency_unit" },
              "minItems": 1,
              "uniqueItems": true
            },
            "service": {
              "type": "array",
              "items": { "$ref": "#/$defs/service_unit" },
              "minItems": 1,
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "currency_code": {
      "type": "string",
      "enum": ["AUD", "USD"],
      "description": "Supported ISO currency codes for monetary normalization"
    },
    "monetary_unit_token": {
      "type": "string",
      "pattern": "^[kMB]?[A-Z]{3}([0-9]{2}|[0-9]{4})$",
      "description": "Monetary shorthand token (e.g., MAUD24, USD23, kUSD2014)"
    },
    "cost_rate_literal": {
      "type": "string",
      "pattern": "^[+-]?[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?\\s+[kMB]?[A-Z]{3}([0-9]{2}|[0-9]{4})/[A-Za-z][A-Za-z0-9]*(?:/[A-Za-z][A-Za-z0-9]*)?(?:/yr)?$",
      "description": "Explicit cost literal (e.g., '15 MUSD23/PJ', '20 MAUD24/Bvkm/yr')"
    },
    "time_varying_cost_rate": {
      "type": "object",
      "required": ["values"],
      "properties": {
        "values": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/cost_rate_literal" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ]
        }
      },
      "additionalProperties": false
    },
    "monetary_policy": {
      "type": "object",
      "required": ["canonical"],
      "properties": {
        "canonical": {
          "$ref": "#/$defs/monetary_unit_token",
          "description": "Canonical emitted monetary unit token (e.g., MAUD24)"
        },
        "fx_table": {
          "type": "string",
          "description": "Path to FX conversion table used for cross-currency normalization"
        },
        "cpi_tables": {
          "type": "object",
          "description": "Optional CPI index tables keyed by currency code for year normalization",
          "propertyNames": { "$ref": "#/$defs/currency_code" },
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "process_activity_unit": {
      "oneOf": [
        { "$ref": "#/$defs/energy_unit" },
        { "$ref": "#/$defs/service_unit" },
        { "$ref": "#/$defs/mass_unit" }
      ],
      "description": "Process activity unit (annual extensive quantity basis: energy, service, or mass)"
    },
    "process_rate_unit": {
      "type": "string",
      "enum": [
        "PJ/yr", "TJ/yr", "GJ/yr", "MWh/yr", "GWh/yr", "TWh/yr", "MTOE/yr", "KTOE/yr",
        "Bvkm/yr",
        "Mt/yr", "kt/yr", "t/yr", "Gt/yr"
      ],
      "description": "Explicit annual rate unit (<unit>/yr)"
    },
    "process_capacity_unit": {
      "oneOf": [
        { "$ref": "#/$defs/power_unit" },
        { "$ref": "#/$defs/process_rate_unit" }
      ],
      "description": "Process capacity unit (instantaneous power or explicit annual throughput rate)"
    },
    "process_role": {
      "type": "object",
      "description": "Abstract process contract defining minimum required I/O that any implementing variant must satisfy.",
      "required": [
        "id",
        "activity_unit",
        "capacity_unit",
        "required_inputs",
        "required_outputs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Role identifier (verb_phrase, snake_case, e.g., generate_electricity)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable role description"
        },
        "stage": {
          "type": "string",
          "enum": ["supply", "conversion", "distribution", "storage", "end_use", "sink"],
          "description": "Optional stage classification (descriptive, for layout/sankey)"
        },
        "activity_unit": {
          "$ref": "#/$defs/process_activity_unit",
          "description": "Activity unit shared by all variants implementing this role"
        },
        "capacity_unit": {
          "$ref": "#/$defs/process_capacity_unit",
          "description": "Capacity unit shared by all variants implementing this role"
        },
        "required_inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/role_flow" },
          "description": "Minimum required input commodities. Every variant must include these in its inputs."
        },
        "required_outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/role_flow" },
          "description": "Minimum required output commodities. Every variant must include these in its outputs."
        }
      },
      "additionalProperties": false
    },
    "role_flow": {
      "type": "object",
      "description": "Commodity reference in a role input/output",
      "required": ["commodity"],
      "properties": {
        "commodity": {
          "type": "string",
          "description": "Reference to commodity id"
        }
      },
      "additionalProperties": false
    },
    "variant_flow": {
      "type": "object",
      "description": "Commodity reference in a variant input/output with optional validation-only coefficient anchor",
      "required": ["commodity"],
      "properties": {
        "commodity": {
          "type": "string",
          "description": "Reference to commodity id"
        },
        "coefficient": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Validation-only anchor coefficient in commodity_unit/activity_unit. Used for unit/magnitude checks; compiler emission remains based on topology + efficiency."
        }
      },
      "additionalProperties": false
    },
    "process_variant": {
      "type": "object",
      "description": "Concrete technology implementing a process role. Declares full explicit I/O (no inheritance from role).",
      "required": ["id", "role", "inputs", "outputs"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Variant identifier (snake_case technology name)"
        },
        "role": {
          "type": "string",
          "description": "Reference to process_role id"
        },
        "description": {
          "type": "string",
          "description": "Human-readable variant description"
        },
        "notes": {
          "type": "string",
          "description": "Optional implementation notes (recommended for negative emission factors)"
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/variant_flow" },
          "description": "Full list of input commodities consumed by this variant. Must include all role required_inputs."
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/variant_flow" },
          "description": "Full list of output commodities produced by this variant. Must include all role required_outputs."
        },
        "kind": {
          "type": "string",
          "enum": ["device", "storage", "generator", "network"],
          "description": "Optional semantic kind for diagnostics metadata. When omitted, compiler derives it."
        },
        "efficiency": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Conversion performance value. Interpreted by performance_metric (efficiency or COP)."
        },
        "performance_metric": {
          "type": "string",
          "enum": ["efficiency", "cop"],
          "default": "efficiency",
          "description": "Interpretation of efficiency value. Use 'cop' for heat-pump style components where values > 1 are expected."
        },
        "lifetime": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Technical lifetime in years"
        },
        "investment_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" },
            { "$ref": "#/$defs/cost_rate_literal" },
            { "$ref": "#/$defs/time_varying_cost_rate" }
          ],
          "description": "Capital cost per unit capacity"
        },
        "fixed_om_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" },
            { "$ref": "#/$defs/cost_rate_literal" },
            { "$ref": "#/$defs/time_varying_cost_rate" }
          ],
          "description": "Fixed O&M cost per unit capacity per year"
        },
        "variable_om_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" },
            { "$ref": "#/$defs/cost_rate_literal" },
            { "$ref": "#/$defs/time_varying_cost_rate" }
          ],
          "description": "Variable O&M cost per unit activity"
        },
        "emission_factors": {
          "type": "object",
          "description": "Per-emission-commodity factors keyed by commodity id, per unit PROCESS ACTIVITY (TIMES ENV_ACT). Values are scalars or time-varying specs.",
          "additionalProperties": {
            "oneOf": [
              { "type": "number" },
              { "$ref": "#/$defs/time_varying_value" }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "availability_entry": {
      "type": "object",
      "description": "Defines where a variant is available",
      "required": ["variant", "regions"],
      "properties": {
        "variant": {
          "type": "string",
          "description": "Reference to process_variant id"
        },
        "regions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Regions where the variant is available"
        },
        "sectors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional sector filter (from segments.sectors)"
        },
        "segments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional segment filter (sector.end_use keys)"
        }
      },
      "additionalProperties": false
    },
    "process_parameter": {
      "type": "object",
      "description": "Selector-based parameter block for variant instances",
      "required": ["selector"],
      "properties": {
        "selector": {
          "$ref": "#/$defs/parameter_selector",
          "description": "Identifies which variant instances this applies to"
        },
        "existing_capacity": {
          "type": "array",
          "items": { "$ref": "#/$defs/past_investment" },
          "description": "Past capacity investments (NCAP_PASTI)"
        },
        "cap_bound": {
          "$ref": "#/$defs/bound",
          "description": "Capacity bounds"
        },
        "ncap_bound": {
          "$ref": "#/$defs/bound",
          "description": "New capacity bounds"
        },
        "activity_bound": {
          "$ref": "#/$defs/bound",
          "description": "Activity bounds"
        },
        "stock": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Stock value"
        }
      },
      "additionalProperties": false
    },
    "parameter_selector": {
      "type": "object",
      "description": "Selector for parameter blocks",
      "required": ["variant", "region"],
      "properties": {
        "variant": {
          "type": "string",
          "description": "Reference to process_variant id"
        },
        "region": {
          "type": "string",
          "description": "Region code"
        },
        "sector": {
          "type": "string",
          "description": "Optional sector filter"
        },
        "segment": {
          "type": "string",
          "description": "Optional segment filter (sector.end_use)"
        }
      },
      "additionalProperties": false
    },
    "demand": {
      "type": "object",
      "description": "Service commodity demand specification",
      "required": ["commodity", "region", "values"],
      "properties": {
        "commodity": {
          "type": "string",
          "description": "Reference to service commodity id"
        },
        "region": {
          "type": "string",
          "description": "Region code"
        },
        "sector": {
          "type": "string",
          "description": "Optional sector (from segments.sectors)"
        },
        "segment": {
          "type": "string",
          "description": "Optional segment (sector.end_use)"
        },
        "values": {
          "type": "object",
          "description": "Year -> demand value mapping",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "description": "VEDA interpolation/extrapolation mode"
        }
      },
      "additionalProperties": false
    },
    "category": {
      "type": "string",
      "enum": [
        "demands",
        "prices",
        "policies",
        "technology_assumptions",
        "resource_availability",
        "global_settings"
      ],
      "description": "Scenario category for organizing parameters into logical groups"
    },
    "case": {
      "type": "object",
      "description": "A model case - a named combination of scenario parameters for a specific model run",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Case identifier (lowercase, used in file names: Scen_{case}_{category}.xlsx)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable case description"
        },
        "is_baseline": {
          "type": "boolean",
          "default": false,
          "description": "Marks this case as the baseline/reference case"
        },
        "includes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of scenario parameter names to include in this case. If omitted, includes all parameters."
        },
        "excludes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of scenario parameter names to exclude from this case"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional labels for categorizing cases (e.g., 'policy', 'reference', 'sensitivity')"
        },
        "demand_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/case_demand_override" },
          "description": "Per-case demand overrides/scaling"
        },
        "fuel_price_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/case_price_override" },
          "description": "Per-case commodity price overrides"
        },
        "constraint_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/case_constraint_override" },
          "description": "Per-case enable/disable and parameter overrides for constraints"
        },
        "variant_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/case_variant_override" },
          "description": "Per-case variant overrides (cost/performance, or disable via generated bounds)"
        }
      },
      "additionalProperties": false
    },
    "study": {
      "type": "object",
      "description": "A study - a collection of cases for comparison",
      "required": ["name", "cases"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Study name"
        },
        "description": {
          "type": "string",
          "description": "Human-readable study description"
        },
        "cases": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "List of case names included in this study"
        }
      },
      "additionalProperties": false
    },
    "constraint": {
      "type": "object",
      "description": "User constraint definition (emission_cap or activity_share)",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Constraint name (becomes UC_N in TIMES)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable constraint description"
        },
        "type": {
          "type": "string",
          "enum": ["emission_cap", "activity_share"],
          "description": "Type of constraint"
        },
        "category": {
          "$ref": "#/$defs/category",
          "description": "Scenario category (default: 'policies' for constraints)"
        },
        "commodity": {
          "type": "string",
          "description": "Target commodity for the constraint"
        },
        "processes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of process names (for activity_share)"
        },
        "limit": {
          "type": "number",
          "description": "RHS value for emission_cap constraints"
        },
        "limtype": {
          "type": "string",
          "enum": ["up", "lo", "fx"],
          "default": "up",
          "description": "Limit type: up (max), lo (min), or fx (fixed)"
        },
        "minimum_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum share for activity_share constraints (0-1)"
        },
        "maximum_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Maximum share for activity_share constraints (0-1)"
        },
        "years": {
          "type": "object",
          "description": "Year-specific RHS values (overrides limit)",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "description": "Interpolation mode for year-specific values"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "emission_cap" } } },
          "then": { "required": ["commodity"] }
        },
        {
          "if": { "properties": { "type": { "const": "activity_share" } } },
          "then": { "required": ["commodity", "processes"] }
        }
      ],
      "additionalProperties": false
    },
    "trade_link": {
      "type": "object",
      "description": "Inter-regional trade link for commodity exchange",
      "required": ["origin", "destination", "commodity"],
      "properties": {
        "origin": {
          "type": "string",
          "description": "Origin region code"
        },
        "destination": {
          "type": "string",
          "description": "Destination region code"
        },
        "commodity": {
          "type": "string",
          "description": "Traded commodity name"
        },
        "bidirectional": {
          "type": "boolean",
          "default": false,
          "description": "If true, trade can flow in both directions"
        },
        "efficiency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0,
          "description": "Trade efficiency (losses during transport)"
        },
        "cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Transport cost per unit"
        },
        "capacity": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Maximum trade capacity"
        }
      },
      "additionalProperties": false
    },
    "timeslices": {
      "type": "object",
      "description": "Timeslice structure for intra-annual temporal resolution",
      "properties": {
        "season": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeslice_level" },
          "description": "Seasonal level (e.g., Summer, Winter)"
        },
        "weekly": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeslice_level" },
          "description": "Weekly level (e.g., Weekday, Weekend)"
        },
        "daynite": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeslice_level" },
          "description": "Day/night level (e.g., Day, Night, Peak)"
        },
        "fractions": {
          "type": "object",
          "description": "Mapping of timeslice code to annual fraction (must sum to 1.0)",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "additionalProperties": false
    },
    "timeslice_level": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z]{1,3}$",
          "description": "Timeslice code (1-3 uppercase letters)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name"
        }
      },
      "additionalProperties": false
    },
    "commodity_namespace": {
      "type": "string",
      "enum": [
        "primary",
        "resource",
        "secondary",
        "service",
        "material",
        "emission",
        "money"
      ],
      "description": "Canonical namespace prefixes allowed in commodity identifiers"
    },
    "commodity": {
      "type": "object",
      "description": "Commodity definition",
      "required": ["type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(?:(?:primary|resource|secondary|service|material|emission|money):)?[a-z][a-z0-9_-]*$",
          "description": "Commodity identifier (snake_case noun, preferred over 'name'). Namespaced form must use a canonical prefix from $defs.commodity_namespace (e.g., secondary:electricity, primary:natural_gas)."
        },
        "name": {
          "type": "string",
          "description": "Legacy commodity name (deprecated, use 'id' instead)"
        },
        "type": {
          "type": "string",
          "enum": ["fuel", "energy", "service", "material", "emission", "money", "other"],
          "description": "Canonical commodity type used by diagnostics semantics and COM_TYPE mapping."
        },
        "unit": {
          "$ref": "#/$defs/unit_symbol",
          "description": "Unit of measurement (e.g., PJ, Mt)"
        },
        "basis": {
          "$ref": "#/$defs/energy_basis",
          "description": "Energy basis used for this commodity when relevant to energy/mass consistency"
        },
        "description": {
          "type": "string",
          "description": "Human-readable commodity description"
        },
        "tradable": {
          "type": "boolean",
          "description": "Whether commodity can be traded between regions (default: true for fuel/energy/material/other, false for service/emission)"
        },
        "timesliced": {
          "type": "boolean",
          "default": false,
          "description": "Whether this commodity is tracked at timeslice resolution"
        },
        "peak_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Peak demand fraction for capacity adequacy"
        }
      },
      "additionalProperties": false
    },
    "case_demand_override": {
      "type": "object",
      "required": ["commodity"],
      "properties": {
        "commodity": { "type": "string" },
        "region": { "type": "string" },
        "sector": { "type": "string" },
        "segment": { "type": "string" },
        "scale": { "type": "number", "minimum": 0 },
        "values": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ]
        }
      },
      "additionalProperties": false
    },
    "case_price_override": {
      "type": "object",
      "required": ["commodity", "values"],
      "properties": {
        "commodity": { "type": "string" },
        "values": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "default": "interp_extrap"
        }
      },
      "additionalProperties": false
    },
    "case_constraint_override": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "enabled": { "type": "boolean", "default": true },
        "limit": { "type": "number" },
        "limtype": {
          "type": "string",
          "enum": ["up", "lo", "fx"]
        },
        "minimum_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "maximum_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "years": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        }
      },
      "additionalProperties": false
    },
    "case_variant_override": {
      "type": "object",
      "required": ["variant"],
      "properties": {
        "variant": { "type": "string" },
        "enabled": { "type": "boolean", "default": true },
        "efficiency": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ]
        },
        "investment_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" },
            { "$ref": "#/$defs/cost_rate_literal" },
            { "$ref": "#/$defs/time_varying_cost_rate" }
          ]
        },
        "fixed_om_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" },
            { "$ref": "#/$defs/cost_rate_literal" },
            { "$ref": "#/$defs/time_varying_cost_rate" }
          ]
        },
        "variable_om_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" },
            { "$ref": "#/$defs/cost_rate_literal" },
            { "$ref": "#/$defs/time_varying_cost_rate" }
          ]
        },
        "lifetime": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ]
        }
      },
      "additionalProperties": false
    },
    "diagnostics_boundary": {
      "type": "object",
      "required": ["id", "measure"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "measure": {
          "type": "string",
          "enum": ["end_use_inputs", "service_outputs", "generation_outputs", "emissions_net"]
        },
        "selectors": { "$ref": "#/$defs/diagnostics_selectors" }
      },
      "additionalProperties": false
    },
    "diagnostics_selectors": {
      "type": "object",
      "properties": {
        "stage_in": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["supply", "conversion", "distribution", "storage", "end_use", "sink"]
          }
        },
        "sector_in": {
          "type": "array",
          "items": { "type": "string" }
        },
        "service_in": {
          "type": "array",
          "items": { "type": "string" }
        },
        "kind_in": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["device", "storage", "generator", "network"]
          }
        },
        "include_any": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude_any": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "diagnostics_metric": {
      "type": "object",
      "required": ["id", "type", "boundary"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "fuel_use_by_carrier",
            "fuel_switch",
            "share_change",
            "intensity_change",
            "demand_change",
            "delta"
          ]
        },
        "boundary": { "type": "string" },
        "from_case": { "type": "string" },
        "to_case": { "type": "string" }
      },
      "additionalProperties": false
    },
    "diagnostics_spec": {
      "type": "object",
      "properties": {
        "on_empty_boundary": {
          "type": "string",
          "enum": ["warn", "error"],
          "default": "warn"
        },
        "boundaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostics_boundary" }
        },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostics_metric" }
        }
      },
      "additionalProperties": false
    },
    "past_investment": {
      "type": "object",
      "description": "A past capacity investment with specific vintage year (NCAP_PASTI)",
      "required": ["vintage", "capacity"],
      "properties": {
        "vintage": {
          "type": "integer",
          "minimum": 1900,
          "description": "Year the capacity was built (pastyear in TIMES). Determines when capacity retires based on lifetime."
        },
        "capacity": {
          "type": "number",
          "minimum": 0,
          "description": "Installed capacity amount in capacity_unit (e.g., GW)"
        }
      },
      "additionalProperties": false
    },
    "bound": {
      "type": "object",
      "description": "Bound specification with optional upper, lower, and fixed limits",
      "properties": {
        "up": {
          "type": "number",
          "minimum": 0,
          "description": "Upper bound (maximum allowed)"
        },
        "lo": {
          "type": "number",
          "minimum": 0,
          "description": "Lower bound (minimum required)"
        },
        "fx": {
          "type": "number",
          "minimum": 0,
          "description": "Fixed bound (exact value)"
        }
      },
      "additionalProperties": false
    },
    "flow": {
      "type": "object",
      "required": ["commodity"],
      "properties": {
        "commodity": { "type": "string", "description": "Reference to commodity name" },
        "share": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0, "description": "Flow share for non-emission outputs (FLO_SHAR)" },
        "coefficient": { "type": "number", "exclusiveMinimum": 0, "description": "Validation-only anchor coefficient in commodity_unit/activity_unit. Used for lint/compile unit checks; emission semantics remain driven by topology + efficiency." },
        "emission_factor": { "type": "number", "description": "Emission per unit PROCESS ACTIVITY. Units: <emission_commodity.unit> per <process.activity_unit> (e.g., Mt CO2 per PJ activity). Implemented via ENV_ACT in TIMES, which xl2times maps to FLO_EMIS. Always per-activity, NOT per-flow. Use instead of 'share' for emission commodities." }
      }
    },
    "scenario_parameter": {
      "type": "object",
      "description": "A scenario parameter - an atomic time-series or value assumption (e.g., CO2 price path, demand projection)",
      "required": ["name", "type"],
      "properties": {
        "name": { 
          "type": "string", 
          "description": "Parameter name identifier"
        },
        "description": { 
          "type": "string",
          "description": "Human-readable parameter description"
        },
        "type": {
          "type": "string",
          "enum": ["commodity_price", "demand_projection"],
          "description": "Type of scenario parameter"
        },
        "category": {
          "$ref": "#/$defs/category",
          "description": "Scenario category. Defaults: commodity_price→prices, demand_projection→demands"
        },
        "commodity": {
          "type": "string",
          "description": "Target commodity for this parameter"
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "description": "VEDA interpolation/extrapolation mode (REQUIRED). Maps to year=0 option codes: none=-1, interp_only=1, interp_extrap_eps=2, interp_extrap=3, interp_extrap_back=4, interp_extrap_forward=5"
        },
        "values": {
          "type": "object",
          "description": "Year -> value mapping for time-series data (sparse OK, compiler expands)",
          "additionalProperties": { "type": "number" },
          "propertyNames": {
            "pattern": "^[12][0-9]{3}$",
            "description": "Keys must be 4-digit years"
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "commodity_price" } } },
          "then": { "required": ["commodity", "values", "interpolation"] }
        },
        {
          "if": { "properties": { "type": { "const": "demand_projection" } } },
          "then": { "required": ["commodity", "values", "interpolation"] }
        }
      ]
    },
    "time_series": {
      "type": "object",
      "description": "Generic time-series specification with REQUIRED interpolation mode",
      "properties": {
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "description": "VEDA interpolation/extrapolation mode (REQUIRED)"
        },
        "values": {
          "type": "object",
          "description": "Year -> value mapping",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        }
      },
      "required": ["values", "interpolation"]
    },
    "time_varying_value": {
      "type": "object",
      "description": "Time-varying process attribute with year->value mapping and optional interpolation",
      "properties": {
        "values": {
          "type": "object",
          "description": "Year -> value mapping (e.g., {\"2020\": 1000, \"2030\": 600})",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "default": "interp_extrap",
          "description": "VEDA interpolation/extrapolation mode (default: interp_extrap)"
        }
      },
      "required": ["values"],
      "additionalProperties": false
    }
  }
}
