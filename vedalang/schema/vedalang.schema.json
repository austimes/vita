{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://veda-devtools/vedalang.schema.json",
  "title": "VedaLang Model",
  "description": "Schema for VedaLang source files - a typed DSL for VEDA models",
  "type": "object",
  "required": ["model"],
  "properties": {
    "model": {
      "type": "object",
      "required": ["name", "regions", "commodities", "processes"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Model name identifier"
        },
        "description": {
          "type": "string",
          "description": "Model description"
        },
        "regions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "List of region codes"
        },
        "start_year": {
          "type": "integer",
          "description": "Model start year (default: 2020)"
        },
        "time_periods": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "description": "Period lengths in years (e.g., [10, 10, 10] for three 10-year periods)"
        },
        "timeslices": {
          "$ref": "#/$defs/timeslices",
          "description": "Timeslice structure for intra-annual temporal resolution"
        },
        "commodities": {
          "type": "array",
          "items": { "$ref": "#/$defs/commodity" },
          "description": "Commodity definitions"
        },
        "processes": {
          "type": "array",
          "items": { "$ref": "#/$defs/process" },
          "description": "Process definitions"
        },
        "scenario_parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario_parameter" },
          "description": "Scenario parameters (demand projections, prices, etc.)"
        },
        "trade_links": {
          "type": "array",
          "items": { "$ref": "#/$defs/trade_link" },
          "description": "Inter-regional trade links"
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" },
          "description": "User constraints (emission caps, activity shares, etc.)"
        },
        "cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/case" },
          "description": "Model cases - named combinations of scenario parameters for different model runs"
        },
        "studies": {
          "type": "array",
          "items": { "$ref": "#/$defs/study" },
          "description": "Studies - collections of cases for comparison"
        },
        "scenarios": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenario_parameter" },
          "description": "DEPRECATED: Use 'scenario_parameters' instead. Kept for backward compatibility."
        }
      }
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "demands",
        "prices",
        "policies",
        "technology_assumptions",
        "resource_availability",
        "global_settings"
      ],
      "description": "Scenario category for organizing parameters into logical groups"
    },
    "case": {
      "type": "object",
      "description": "A model case - a named combination of scenario parameters for a specific model run",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Case identifier (lowercase, used in file names: Scen_{case}_{category}.xlsx)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable case description"
        },
        "is_baseline": {
          "type": "boolean",
          "default": false,
          "description": "Marks this case as the baseline/reference case"
        },
        "includes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of scenario parameter names to include in this case. If omitted, includes all parameters."
        },
        "excludes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of scenario parameter names to exclude from this case"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional labels for categorizing cases (e.g., 'policy', 'reference', 'sensitivity')"
        }
      },
      "additionalProperties": false
    },
    "study": {
      "type": "object",
      "description": "A study - a collection of cases for comparison",
      "required": ["name", "cases"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Study name"
        },
        "description": {
          "type": "string",
          "description": "Human-readable study description"
        },
        "cases": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "List of case names included in this study"
        }
      },
      "additionalProperties": false
    },
    "constraint": {
      "type": "object",
      "description": "User constraint definition (emission_cap or activity_share)",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Constraint name (becomes UC_N in TIMES)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable constraint description"
        },
        "type": {
          "type": "string",
          "enum": ["emission_cap", "activity_share"],
          "description": "Type of constraint"
        },
        "category": {
          "$ref": "#/$defs/category",
          "description": "Scenario category (default: 'policies' for constraints)"
        },
        "commodity": {
          "type": "string",
          "description": "Target commodity for the constraint"
        },
        "processes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of process names (for activity_share)"
        },
        "limit": {
          "type": "number",
          "description": "RHS value for emission_cap constraints"
        },
        "limtype": {
          "type": "string",
          "enum": ["up", "lo", "fx"],
          "default": "up",
          "description": "Limit type: up (max), lo (min), or fx (fixed)"
        },
        "minimum_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum share for activity_share constraints (0-1)"
        },
        "maximum_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Maximum share for activity_share constraints (0-1)"
        },
        "years": {
          "type": "object",
          "description": "Year-specific RHS values (overrides limit)",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "description": "Interpolation mode for year-specific values"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "emission_cap" } } },
          "then": { "required": ["commodity"] }
        },
        {
          "if": { "properties": { "type": { "const": "activity_share" } } },
          "then": { "required": ["commodity", "processes"] }
        }
      ],
      "additionalProperties": false
    },
    "trade_link": {
      "type": "object",
      "description": "Inter-regional trade link for commodity exchange",
      "required": ["origin", "destination", "commodity"],
      "properties": {
        "origin": {
          "type": "string",
          "description": "Origin region code"
        },
        "destination": {
          "type": "string",
          "description": "Destination region code"
        },
        "commodity": {
          "type": "string",
          "description": "Traded commodity name"
        },
        "bidirectional": {
          "type": "boolean",
          "default": true,
          "description": "Whether trade flows in both directions"
        },
        "efficiency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Transport efficiency (1.0 = no losses)"
        }
      },
      "additionalProperties": false
    },
    "timeslice_level": {
      "type": "object",
      "description": "A single timeslice code within a level (season/weekly/daynite)",
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z]{1,3}$",
          "description": "Short code (1-3 uppercase chars) for this timeslice"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name (e.g., 'Summer', 'Day')"
        }
      },
      "additionalProperties": false
    },
    "timeslices": {
      "type": "object",
      "description": "Timeslice structure for intra-annual variation",
      "properties": {
        "season": {
          "type": "array",
          "description": "Seasonal timeslice codes (e.g., Summer, Winter)",
          "items": { "$ref": "#/$defs/timeslice_level" }
        },
        "weekly": {
          "type": "array",
          "description": "Weekly timeslice codes (rarely used)",
          "items": { "$ref": "#/$defs/timeslice_level" }
        },
        "daynite": {
          "type": "array",
          "description": "Day/night timeslice codes",
          "items": { "$ref": "#/$defs/timeslice_level" }
        },
        "fractions": {
          "type": "object",
          "description": "Year fraction for each composite timeslice (must sum to 1.0). Keys are auto-generated: SEASON + WEEKLY + DAYNITE.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "additionalProperties": false
    },
    "commodity": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "description": "Commodity identifier (e.g., ELC, NG, CO2)" },
        "type": { 
          "type": "string",
          "enum": ["energy", "material", "emission", "demand"],
          "description": "Commodity type: energy (fuels, electricity), material (hydrogen, steel), emission (CO2, NOx), demand (end-use services)"
        },
        "unit": { 
          "type": "string", 
          "description": "Unit of measurement. Defaults: energy/demand→PJ, emission/material→Mt"
        },
        "description": { "type": "string", "description": "Human-readable commodity description" }
      }
    },
    "process": {
      "type": "object",
      "required": ["name", "sets", "primary_commodity_group", "efficiency"],
      "properties": {
        "name": { "type": "string", "description": "Process identifier (e.g., PP_CCGT, IMP_NG)" },
        "description": { "type": "string", "description": "Human-readable process description" },
        "sets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Process set memberships (e.g., ELE for electricity, DMD for demand, IMP for import)"
        },
        "primary_commodity_group": {
          "type": "string",
          "enum": ["DEMI", "DEMO", "MATI", "MATO", "NRGI", "NRGO", "ENVI", "ENVO", "FINI", "FINO"],
          "description": "Primary commodity group (PCG). REQUIRED. Defines which commodity flows determine process activity. Common values: NRGO (energy output), DEMO (demand output), MATO (material output)."
        },
        "activity_unit": { "type": "string", "default": "PJ", "description": "Unit for process activity (default: PJ)" },
        "capacity_unit": { "type": "string", "default": "GW", "description": "Unit for process capacity (default: GW)" },
        "input": {
          "type": "string",
          "description": "Single input commodity name (shorthand for inputs with one item)"
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/flow" },
          "description": "Input commodity flows (use 'input' for single commodity shorthand)"
        },
        "output": {
          "type": "string",
          "description": "Single output commodity name (shorthand for outputs with one item)"
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/flow" },
          "description": "Output commodity flows (use 'output' for single commodity shorthand)"
        },
        "efficiency": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "REQUIRED. Process efficiency (0-1), ratio of useful output to input. Must be explicitly specified for all processes, including demand devices and sources. Use 1.0 for lossless pass-through."
        },
        "investment_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Investment cost per unit of new capacity (NCAP_COST). Units: $/GW or specified currency/capacity_unit."
        },
        "fixed_om_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Fixed O&M cost per unit capacity per year (NCAP_FOM). Units: $/GW/yr."
        },
        "variable_om_cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Variable O&M cost per unit of activity (ACT_COST). Units: $/PJ or $/activity_unit."
        },
        "import_price": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Price for imported commodity (IRE_PRICE). Only valid for IMP/EXP processes. Units: $/PJ."
        },
        "lifetime": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Technical lifetime of new capacity (NCAP_TLIFE). Units: years."
        },
        "invcost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "DEPRECATED: Use 'investment_cost'. Investment cost per unit capacity (NCAP_COST)."
        },
        "fixom": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "DEPRECATED: Use 'fixed_om_cost'. Fixed O&M per unit capacity per year (NCAP_FOM)."
        },
        "varom": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "DEPRECATED: Use 'variable_om_cost'. Variable O&M per unit activity (ACT_COST)."
        },
        "life": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "DEPRECATED: Use 'lifetime'. Technical lifetime in years (NCAP_TLIFE)."
        },
        "cost": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "DEPRECATED: Ambiguous - use 'variable_om_cost' for activity cost or 'import_price' for IMP/EXP processes."
        },
        "availability_factor": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Availability factor (0-1). Can be scalar or time-varying."
        },
        "activity_bound": {
          "$ref": "#/$defs/bound",
          "description": "Bounds on annual activity (ACT_BND)"
        },
        "cap_bound": {
          "$ref": "#/$defs/bound",
          "description": "Bounds on total installed capacity (CAP_BND)"
        },
        "ncap_bound": {
          "$ref": "#/$defs/bound",
          "description": "Bounds on new capacity per period (NCAP_BND)"
        },
        "stock": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "$ref": "#/$defs/time_varying_value" }
          ],
          "description": "Initial/residual capacity (PRC_RESID/STOCK). Pre-existing capacity before model start."
        }
      }
    },
    "bound": {
      "type": "object",
      "description": "Bound specification with optional upper, lower, and fixed limits",
      "properties": {
        "up": {
          "type": "number",
          "minimum": 0,
          "description": "Upper bound (maximum allowed)"
        },
        "lo": {
          "type": "number",
          "minimum": 0,
          "description": "Lower bound (minimum required)"
        },
        "fx": {
          "type": "number",
          "minimum": 0,
          "description": "Fixed bound (exact value)"
        }
      },
      "additionalProperties": false
    },
    "flow": {
      "type": "object",
      "required": ["commodity"],
      "properties": {
        "commodity": { "type": "string", "description": "Reference to commodity name" },
        "share": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0, "description": "Flow share for non-emission outputs (FLO_SHAR)" },
        "emission_factor": { "type": "number", "minimum": 0, "description": "Emission per unit PROCESS ACTIVITY. Units: <emission_commodity.unit> per <process.activity_unit> (e.g., Mt CO2 per PJ activity). Implemented via ENV_ACT in TIMES, which xl2times maps to FLO_EMIS. Always per-activity, NOT per-flow. Use instead of 'share' for emission commodities." }
      }
    },
    "scenario_parameter": {
      "type": "object",
      "description": "A scenario parameter - an atomic time-series or value assumption (e.g., CO2 price path, demand projection)",
      "required": ["name", "type"],
      "properties": {
        "name": { 
          "type": "string", 
          "description": "Parameter name identifier"
        },
        "description": { 
          "type": "string",
          "description": "Human-readable parameter description"
        },
        "type": {
          "type": "string",
          "enum": ["commodity_price", "demand_projection"],
          "description": "Type of scenario parameter"
        },
        "category": {
          "$ref": "#/$defs/category",
          "description": "Scenario category. Defaults: commodity_price→prices, demand_projection→demands"
        },
        "commodity": {
          "type": "string",
          "description": "Target commodity for this parameter"
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "description": "VEDA interpolation/extrapolation mode (REQUIRED). Maps to year=0 option codes: none=-1, interp_only=1, interp_extrap_eps=2, interp_extrap=3, interp_extrap_back=4, interp_extrap_forward=5"
        },
        "values": {
          "type": "object",
          "description": "Year -> value mapping for time-series data (sparse OK, compiler expands)",
          "additionalProperties": { "type": "number" },
          "propertyNames": {
            "pattern": "^[12][0-9]{3}$",
            "description": "Keys must be 4-digit years"
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "commodity_price" } } },
          "then": { "required": ["commodity", "values", "interpolation"] }
        },
        {
          "if": { "properties": { "type": { "const": "demand_projection" } } },
          "then": { "required": ["commodity", "values", "interpolation"] }
        }
      ]
    },
    "time_series": {
      "type": "object",
      "description": "Generic time-series specification with REQUIRED interpolation mode",
      "properties": {
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "description": "VEDA interpolation/extrapolation mode (REQUIRED)"
        },
        "values": {
          "type": "object",
          "description": "Year -> value mapping",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        }
      },
      "required": ["values", "interpolation"]
    },
    "time_varying_value": {
      "type": "object",
      "description": "Time-varying process attribute with year->value mapping and optional interpolation",
      "properties": {
        "values": {
          "type": "object",
          "description": "Year -> value mapping (e.g., {\"2020\": 1000, \"2030\": 600})",
          "additionalProperties": { "type": "number" },
          "propertyNames": { "pattern": "^[12][0-9]{3}$" }
        },
        "interpolation": {
          "type": "string",
          "enum": [
            "none",
            "interp_only",
            "interp_extrap_eps",
            "interp_extrap",
            "interp_extrap_back",
            "interp_extrap_forward"
          ],
          "default": "interp_extrap",
          "description": "VEDA interpolation/extrapolation mode (default: interp_extrap)"
        }
      },
      "required": ["values"],
      "additionalProperties": false
    }
  }
}
