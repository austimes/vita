{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://veda-devtools/vedalang.schema.json",
  "title": "VedaLang v0.3 Model",
  "description": "Schema for the v0.3 public VedaLang authoring surface.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "dsl_version": {
      "type": "string",
      "const": "0.3",
      "description": "Declared public DSL version for this source file."
    },
    "imports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/import_decl"
      }
    },
    "commodities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commodity"
      }
    },
    "technologies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/technology"
      }
    },
    "technology_roles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/technology_role"
      }
    },
    "stock_characterizations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stock_characterization"
      }
    },
    "spatial_layers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/spatial_layer"
      }
    },
    "spatial_measure_sets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/spatial_measure_set"
      }
    },
    "temporal_index_series": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/temporal_index_series"
      }
    },
    "region_partitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region_partition"
      }
    },
    "zone_overlays": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/zone_overlay"
      }
    },
    "sites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/site"
      }
    },
    "facilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/facility"
      }
    },
    "fleets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fleet"
      }
    },
    "zone_opportunities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/zone_opportunity"
      }
    },
    "networks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/network"
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/run"
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "imports"
      ]
    },
    {
      "required": [
        "commodities"
      ]
    },
    {
      "required": [
        "technologies"
      ]
    },
    {
      "required": [
        "technology_roles"
      ]
    },
    {
      "required": [
        "stock_characterizations"
      ]
    },
    {
      "required": [
        "spatial_layers"
      ]
    },
    {
      "required": [
        "spatial_measure_sets"
      ]
    },
    {
      "required": [
        "temporal_index_series"
      ]
    },
    {
      "required": [
        "region_partitions"
      ]
    },
    {
      "required": [
        "zone_overlays"
      ]
    },
    {
      "required": [
        "sites"
      ]
    },
    {
      "required": [
        "facilities"
      ]
    },
    {
      "required": [
        "fleets"
      ]
    },
    {
      "required": [
        "zone_opportunities"
      ]
    },
    {
      "required": [
        "networks"
      ]
    },
    {
      "required": [
        "runs"
      ]
    }
  ],
  "$defs": {
    "public_identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$"
    },
    "commodity_identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "zone_reference": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    },
    "commodity_namespace": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "resource",
        "service",
        "material",
        "emission",
        "money",
        "certificate"
      ]
    },
    "quantity": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "ref_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/identifier"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "description_field": {
      "type": "string",
      "minLength": 1
    },
    "import_only": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "commodities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commodity_identifier"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "technologies": {
          "$ref": "#/$defs/ref_array"
        },
        "technology_roles": {
          "$ref": "#/$defs/ref_array"
        },
        "stock_characterizations": {
          "$ref": "#/$defs/ref_array"
        },
        "spatial_layers": {
          "$ref": "#/$defs/ref_array"
        },
        "spatial_measure_sets": {
          "$ref": "#/$defs/ref_array"
        },
        "temporal_index_series": {
          "$ref": "#/$defs/ref_array"
        },
        "region_partitions": {
          "$ref": "#/$defs/ref_array"
        },
        "zone_overlays": {
          "$ref": "#/$defs/ref_array"
        }
      }
    },
    "import_decl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "as",
        "only"
      ],
      "properties": {
        "package": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*@[A-Za-z0-9][A-Za-z0-9_.-]*$"
        },
        "as": {
          "$ref": "#/$defs/identifier"
        },
        "only": {
          "$ref": "#/$defs/import_only"
        }
      }
    },
    "commodity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/commodity_identifier"
        },
        "type": {
          "type": "string",
          "enum": [
            "energy",
            "service",
            "material",
            "emission",
            "money",
            "certificate"
          ]
        },
        "energy_form": {
          "type": "string",
          "enum": [
            "primary",
            "secondary",
            "resource"
          ]
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "energy"
              }
            }
          },
          "then": {
            "required": [
              "energy_form"
            ]
          },
          "else": {
            "not": {
              "required": [
                "energy_form"
              ]
            }
          }
        }
      ]
    },
    "flow_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commodity"
      ],
      "properties": {
        "commodity": {
          "$ref": "#/$defs/commodity_identifier"
        },
        "basis": {
          "type": "string",
          "enum": [
            "HHV",
            "LHV"
          ]
        },
        "coefficient": {
          "$ref": "#/$defs/quantity"
        }
      }
    },
    "performance_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "efficiency",
            "cop",
            "custom"
          ]
        },
        "value": {
          "type": "number"
        }
      }
    },
    "emission_factor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commodity",
        "factor"
      ],
      "properties": {
        "commodity": {
          "$ref": "#/$defs/commodity_identifier"
        },
        "factor": {
          "$ref": "#/$defs/quantity"
        }
      }
    },
    "technology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "provides",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "provides": {
          "$ref": "#/$defs/commodity_identifier"
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flow_spec"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flow_spec"
          }
        },
        "performance": {
          "$ref": "#/$defs/performance_spec"
        },
        "emissions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/emission_factor"
          }
        },
        "investment_cost": {
          "$ref": "#/$defs/quantity"
        },
        "fixed_om": {
          "$ref": "#/$defs/quantity"
        },
        "variable_om": {
          "$ref": "#/$defs/quantity"
        },
        "lifetime": {
          "$ref": "#/$defs/quantity"
        },
        "stock_characterization": {
          "$ref": "#/$defs/identifier"
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "role_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "kind"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/identifier"
        },
        "to": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "type": "string",
          "enum": [
            "retrofit",
            "switch"
          ]
        },
        "cost": {
          "$ref": "#/$defs/quantity"
        },
        "lead_time": {
          "$ref": "#/$defs/quantity"
        }
      }
    },
    "technology_role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "primary_service",
        "technologies",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "primary_service": {
          "$ref": "#/$defs/commodity_identifier"
        },
        "technologies": {
          "$ref": "#/$defs/ref_array"
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/role_transition"
          }
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "metric_conversion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_metric",
        "to_metric",
        "factor"
      ],
      "properties": {
        "from_metric": {
          "type": "string",
          "enum": [
            "asset_count",
            "installed_capacity",
            "annual_activity"
          ]
        },
        "to_metric": {
          "type": "string",
          "enum": [
            "asset_count",
            "installed_capacity",
            "annual_activity"
          ]
        },
        "factor": {
          "$ref": "#/$defs/quantity"
        }
      }
    },
    "stock_characterization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "applies_to",
        "conversions"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "applies_to": {
          "$ref": "#/$defs/ref_array"
        },
        "counted_asset_label": {
          "type": "string",
          "minLength": 1
        },
        "conversions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric_conversion"
          },
          "minItems": 1
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "spatial_layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "key",
        "geometry_file"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "kind": {
          "type": "string",
          "enum": [
            "polygon",
            "point",
            "grid"
          ]
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "geometry_file": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "spatial_measure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "observed_year",
        "unit",
        "file",
        "column"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "observed_year": {
          "type": "integer",
          "minimum": 1900
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "column": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "spatial_measure_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layer",
        "measures"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "layer": {
          "$ref": "#/$defs/identifier"
        },
        "measures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/spatial_measure"
          },
          "minItems": 1
        }
      }
    },
    "temporal_index_series": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "unit",
        "values"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "unit": {
          "type": "string",
          "const": "index"
        },
        "base_year": {
          "type": "integer",
          "minimum": 1900
        },
        "values": {
          "type": "object",
          "patternProperties": {
            "^[0-9]{4}$": {
              "type": "number"
            }
          },
          "additionalProperties": false,
          "minProperties": 1
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "partition_mapping": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "constant"
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "file",
            "source_key",
            "target_key"
          ],
          "properties": {
            "kind": {
              "const": "file"
            },
            "file": {
              "type": "string",
              "minLength": 1
            },
            "source_key": {
              "type": "string",
              "minLength": 1
            },
            "target_key": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "spatial_join"
            },
            "source_key": {
              "type": "string",
              "minLength": 1
            },
            "target_key": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "region_partition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layer",
        "mapping"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "layer": {
          "$ref": "#/$defs/identifier"
        },
        "members": {
          "$ref": "#/$defs/string_array"
        },
        "mapping": {
          "$ref": "#/$defs/partition_mapping"
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "zone_overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layer",
        "key",
        "geometry_file"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "layer": {
          "$ref": "#/$defs/identifier"
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "geometry_file": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "site_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lat",
        "lon"
      ],
      "properties": {
        "lat": {
          "type": "number"
        },
        "lon": {
          "type": "number"
        }
      }
    },
    "feature_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer",
        "id"
      ],
      "properties": {
        "layer": {
          "$ref": "#/$defs/identifier"
        },
        "id": {
          "$ref": "#/$defs/public_identifier"
        }
      }
    },
    "site_location": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "point"
          ]
        },
        {
          "required": [
            "feature_ref"
          ]
        }
      ],
      "properties": {
        "point": {
          "$ref": "#/$defs/site_point"
        },
        "feature_ref": {
          "$ref": "#/$defs/feature_ref"
        }
      }
    },
    "membership_override_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region_partitions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "zone_overlays": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "location"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "location": {
          "$ref": "#/$defs/site_location"
        },
        "membership_overrides": {
          "$ref": "#/$defs/membership_override_block"
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "annual_growth_assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "rate"
      ],
      "properties": {
        "kind": {
          "const": "annual_growth"
        },
        "rate": {
          "$ref": "#/$defs/quantity"
        }
      }
    },
    "base_year_adjustment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "using"
      ],
      "properties": {
        "using": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "$ref": "#/$defs/annual_growth_assumption"
            }
          ]
        },
        "elasticity": {
          "type": "number"
        }
      }
    },
    "observed_value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "year"
      ],
      "properties": {
        "value": {
          "$ref": "#/$defs/quantity"
        },
        "year": {
          "type": "integer",
          "minimum": 1900
        }
      }
    },
    "stock_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "technology",
        "metric",
        "observed"
      ],
      "properties": {
        "technology": {
          "$ref": "#/$defs/identifier"
        },
        "metric": {
          "type": "string",
          "enum": [
            "asset_count",
            "installed_capacity",
            "annual_activity"
          ]
        },
        "observed": {
          "$ref": "#/$defs/observed_value"
        },
        "adjust_to_base_year": {
          "$ref": "#/$defs/base_year_adjustment"
        }
      }
    },
    "stock_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items"
      ],
      "properties": {
        "adjust_to_base_year": {
          "$ref": "#/$defs/base_year_adjustment"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stock_observation"
          },
          "minItems": 1
        }
      }
    },
    "asset_new_build_limit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "technology",
        "max_new_capacity"
      ],
      "properties": {
        "technology": {
          "$ref": "#/$defs/identifier"
        },
        "max_new_capacity": {
          "$ref": "#/$defs/quantity"
        }
      }
    },
    "facility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "site",
        "technology_role",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "site": {
          "$ref": "#/$defs/identifier"
        },
        "technology_role": {
          "$ref": "#/$defs/identifier"
        },
        "available_technologies": {
          "$ref": "#/$defs/ref_array"
        },
        "stock": {
          "$ref": "#/$defs/stock_block"
        },
        "new_build_limits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_new_build_limit"
          },
          "minItems": 1
        },
        "policies": {
          "$ref": "#/$defs/ref_array"
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "distribution_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "proportional",
            "custom",
            "direct"
          ]
        },
        "weight_by": {
          "$ref": "#/$defs/identifier"
        },
        "custom_weights_file": {
          "type": "string",
          "minLength": 1
        },
        "target_regions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "method": {
                "const": "proportional"
              }
            }
          },
          "then": {
            "required": [
              "weight_by"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "method": {
                "const": "custom"
              }
            }
          },
          "then": {
            "required": [
              "custom_weights_file"
            ]
          }
        }
      ]
    },
    "fleet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "technology_role",
        "distribution",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "technology_role": {
          "$ref": "#/$defs/identifier"
        },
        "available_technologies": {
          "$ref": "#/$defs/ref_array"
        },
        "stock": {
          "$ref": "#/$defs/stock_block"
        },
        "new_build_limits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_new_build_limit"
          },
          "minItems": 1
        },
        "distribution": {
          "$ref": "#/$defs/distribution_block"
        },
        "policies": {
          "$ref": "#/$defs/ref_array"
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "region_member_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "partition",
        "member"
      ],
      "properties": {
        "partition": {
          "$ref": "#/$defs/identifier"
        },
        "member": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "zone_opportunity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "technology_role",
        "technology",
        "zone",
        "max_new_capacity",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "technology_role": {
          "$ref": "#/$defs/identifier"
        },
        "technology": {
          "$ref": "#/$defs/identifier"
        },
        "zone": {
          "$ref": "#/$defs/zone_reference"
        },
        "max_new_capacity": {
          "$ref": "#/$defs/quantity"
        },
        "profile_ref": {
          "$ref": "#/$defs/identifier"
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "network_node_basis": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "ref"
          ],
          "properties": {
            "kind": {
              "const": "region_partition"
            },
            "ref": {
              "$ref": "#/$defs/identifier"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "sites"
            }
          }
        }
      ]
    },
    "network_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to",
        "commodity"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "commodity": {
          "$ref": "#/$defs/commodity_identifier"
        },
        "existing_transfer_capacity": {
          "$ref": "#/$defs/quantity"
        },
        "max_new_capacity": {
          "$ref": "#/$defs/quantity"
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "node_basis",
        "links"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "kind": {
          "type": "string",
          "enum": [
            "transmission",
            "pipeline"
          ]
        },
        "node_basis": {
          "$ref": "#/$defs/network_node_basis"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/network_link"
          },
          "minItems": 1
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "base_year",
        "currency_year",
        "region_partition"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_identifier"
        },
        "base_year": {
          "type": "integer",
          "minimum": 1900
        },
        "currency_year": {
          "type": "integer",
          "minimum": 1900
        },
        "region_partition": {
          "$ref": "#/$defs/identifier"
        },
        "temporal_partition": {
          "$ref": "#/$defs/identifier"
        },
        "include_cases": {
          "$ref": "#/$defs/ref_array"
        },
        "enable_policies": {
          "$ref": "#/$defs/ref_array"
        },
        "description": {
          "$ref": "#/$defs/description_field"
        }
      }
    }
  }
}
